{
  "name": "@sb/store",
  "version": "5.0.0",
  "description": "State-Management für Smooth Builder",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks.ts",
      "import": "./src/hooks.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sb/types": "workspace:*",
    "@sb/utils": "workspace:*",
    "@sb/history": "workspace:*",
    "@sb/storage": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "react": "^18.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
